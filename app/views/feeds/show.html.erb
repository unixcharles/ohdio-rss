<h1><%= @feed.name %></h1>

<section class="panel">
  <% rss_url = public_rss_feed_url(@feed) %>
  <p class="meta"><strong>RSS URL:</strong> <%= link_to rss_url, rss_url, target: '_blank', rel: 'noopener' %></p>
</section>

<% if @show_metadata.present? %>
  <section class="panel subheader">
    <% if @show_metadata[:image_url].present? %>
      <%= image_tag rss_image_url(@show_metadata[:image_url]), alt: @show_metadata[:title], class: 'show-thumb' %>
    <% end %>
    <h2><%= @show_metadata[:title] %></h2>
    <h3 class="muted"><%= display_ohdio_type(@show_metadata[:type]) %></h3>
    <p><%= sanitize_description(@show_metadata[:description]) %></p>
    <% if @show_metadata[:url].present? %>
      <p><%= link_to @show_metadata[:url], @show_metadata[:url], target: '_blank', rel: 'noopener' %></p>
    <% end %>
    <div class="clear"></div>
  </section>
<% else %>
  <p>Show metadata is syncing in the background. Refresh in a few moments.</p>
<% end %>

<% if @first_item.present? %>
  <p class="meta"><strong><%= @show_metadata[:chronological_order] ? 'First episode' : 'Latest episode' %></strong></p>
  <% if @first_item.segment? %>
    <%= render 'segment_item', item: @first_item %>
  <% else %>
    <%= render 'episode_item', item: @first_item %>
  <% end %>
<% end %>

<section class="panel">
  <p class="meta"><strong>Replay:</strong> <%= @feed.exclude_replays ? 'No' : 'Yes' %></p>
  <p class="meta"><strong>Max episodes:</strong> <%= @feed.max_episodes %></p>
  <% if @feed.episode_query.present? %>
    <p class="meta"><strong>Episode filter query:</strong> <%= @feed.episode_query %></p>
  <% end %>
  <% if @feed.segment_query.present? %>
    <p class="meta"><strong>Segment filter query:</strong> <%= @feed.segment_query %></p>
  <% end %>
</section>

<p class="actions">
  <%= link_to 'Episode list', episodes_feed_path(@feed) %>
  |
  <%= link_to 'Back to feeds', feeds_path %>
  |
  <%= button_to 'Delete this feed', @feed, method: :delete, form: { class: 'inline-action-form' }, class: 'inline-action-button', data: { turbo_confirm: 'Delete this feed?' } %>
</p>

<%= form_with(model: feed) do |form| %>
  <% if feed.errors.any? %>
    <div class="form-errors">
      <h3><%= pluralize(feed.errors.count, 'error') %> prevented this feed from being saved:</h3>
      <ul>
        <% feed.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-field">
    <%= form.label :name, class: 'form-label' %>
    <%= form.text_field :name, required: true, class: 'form-input' %>
  </div>

  <%= form.hidden_field :show_external_id %>

  <div class="form-field">
    <%= form.label :max_episodes, 'Max episodes', class: 'form-label' %>
    <%= form.number_field :max_episodes,
                          required: true,
                          min: 1,
                          max: Feed::MAX_MAX_EPISODES,
                          step: 1,
                          class: 'form-input' %>
    <small>Sync and include up to <%= Feed::MAX_MAX_EPISODES %> latest episodes.</small>
  </div>

  <div class="form-field">
    <%= form.label :episode_query, 'Episode query', class: 'form-label' %>
    <%= form.text_field :episode_query,
                        placeholder: 'Simon OR Tyler AND NOT Frank',
                        class: 'form-input' %>
    <small>Filter by title/description using AND, OR, NOT.</small>
  </div>

  <div class="form-field">
    <%= form.label :segment_query, 'Segment query', class: 'form-label' %>
    <%= form.text_field :segment_query,
                        placeholder: 'politique OR humour',
                        class: 'form-input' %>
    <small>For segment-based shows, filter stitched segments using AND, OR, NOT.</small>
  </div>

  <div class="form-field">
    <label class="checkbox-label">
      <%= form.check_box :exclude_replays %>
      Exclude replays from RSS and downloads
    </label>
  </div>

  <%= form.submit(feed.persisted? ? 'Save' : 'Create feed', class: 'button-primary') %>
<% end %>

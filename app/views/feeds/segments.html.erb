<h1><%= @feed.name %> - Segments</h1>

<% if @show.present? %>
  <p><strong>Episode:</strong> <%= display_episode_title(@episode.title) %> (<%= @episode.ohdio_episode_id %>)</p>
  <p>Downloads are resolved in background jobs and stored per audio content ID.</p>

  <% if @segments.any? %>
    <% @segments.each_with_index do |segment, index| %>
      <% audio_url = segment.audio_content&.audio_url if segment.audio_content&.resolved? %>
      <div class="episode-item">
        <h3>Segment <%= index + 1 %>: <%= TextEntityNormalizer.call(segment.title) %></h3>
        <p><strong>Duration:</strong> <%= segment.duration %></p>
        <p><strong>Seek time:</strong> <%= segment.seek_time %></p>
        <p><strong>Audio content ID:</strong> <%= segment.audio_content_external_id %></p>
        <p>
          <strong>Download:</strong>
          <% if audio_url.present? %>
            <% start_time = segment.seek_time.to_i %>
            <% duration = segment.duration.to_i %>
            <% timed_audio_url = if duration.positive?
              "#{audio_url}#t=#{start_time},#{start_time + duration}"
            else
              "#{audio_url}#t=#{start_time}"
            end %>
            <%= link_to('Download', timed_audio_url, target: '_blank', rel: 'noopener') %>
          <% elsif segment.audio_content_external_id.present? %>
            Resolving in background...
          <% else %>
            N/A
          <% end %>
        </p>
      </div>
    <% end %>
  <% else %>
    <p>No segments available for this episode.</p>
  <% end %>
<% else %>
  <p>Segment data is syncing in the background. Refresh in a few moments.</p>
<% end %>

<p>
  <%= link_to 'Back to episodes', episodes_feed_path(@feed) %>
  |
  <%= link_to 'Back to feed', feed_path(@feed) %>
  |
  <%= link_to 'Back to feeds', feeds_path %>
</p>

<h1><%= @feed.name %> - Segments</h1>

<% if @show_error.present? %>
  <p style="color: #b91c1c;">
    <strong>Ohdio metadata error:</strong>
    <%= @show_error %>
  </p>
<% else %>
  <p><strong>Episode:</strong> <%= @episode.title %> (<%= @episode.id %>)</p>
  <p>Audio URLs are loaded per segment and cached globally by media ID.</p>

  <% if @segments.any? %>
    <% @segments.each_with_index do |segment, index| %>
      <% audio_url = segment.media_id.present? ? Rails.cache.read(["media-url", segment.media_id]) : nil %>
      <div style="border: 1px solid #ddd; border-radius: 6px; padding: 0.8rem; margin-bottom: 0.8rem;">
        <h3>Segment <%= index + 1 %>: <%= segment.title %></h3>
        <p><strong>Duration:</strong> <%= segment.duration %></p>
        <p><strong>Seek time:</strong> <%= segment.seek_time %></p>
        <p><strong>Media ID:</strong> <%= segment.media_id %></p>
        <p>
          <strong>Audio URL:</strong>
          <% if audio_url.present? %>
            <% start_time = segment.seek_time.to_i %>
            <% duration = segment.duration.to_i %>
            <% timed_audio_url = if duration.positive?
              "#{audio_url}#t=#{start_time},#{start_time + duration}"
            else
              "#{audio_url}#t=#{start_time}"
            end %>
            <%= link_to(timed_audio_url, timed_audio_url, target: '_blank', rel: 'noopener') %>
          <% elsif segment.media_id.present? %>
            <%= link_to 'Load audio URL', episode_segments_feed_path(@feed, episode_id: @episode.id, resolve_media_id: segment.media_id) %>
          <% else %>
            N/A
          <% end %>
        </p>
      </div>
    <% end %>
  <% else %>
    <p>No segments available for this episode.</p>
  <% end %>
<% end %>

<p>
  <%= link_to 'Back to episodes', episodes_feed_path(@feed) %>
  |
  <%= link_to 'Back to feed', feed_path(@feed) %>
  |
  <%= link_to 'Back to feeds', feeds_path %>
</p>

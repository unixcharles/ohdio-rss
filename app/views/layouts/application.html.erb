<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Ohdio Rss" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Ohdio Rss">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app %>
  </head>

  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <%= link_to 'Ohdio RSS', feeds_path, class: 'site-title' %>
        <%= form_with url: search_path, method: :get, local: true, html: { class: 'header-search-form' } do %>
          <%= hidden_field_tag :filter, 'all' %>
          <%= text_field_tag :q, params[:q], placeholder: 'Search shows', class: 'header-search-input', aria: { label: 'Search shows' } %>
          <button type="submit" class="header-search-button" aria-label="Search">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M10.5 3a7.5 7.5 0 1 0 4.71 13.34l4.22 4.22 1.06-1.06-4.22-4.22A7.5 7.5 0 0 0 10.5 3Zm0 1.5a6 6 0 1 1 0 12 6 6 0 0 1 0-12Z"/>
            </svg>
          </button>
        <% end %>
      </div>
    </header>

    <main class="page-shell">
      <% if notice.present? %>
        <p><%= notice %></p>
      <% end %>

      <% if alert.present? %>
        <p><%= alert %></p>
      <% end %>

      <%= yield %>
    </main>
    <script type="module">
      let activeAudio = null;
      let activePlayer = null;

      function fmt(secs) {
        if (!isFinite(secs) || secs < 0) return '0:00';
        const t = Math.floor(secs);
        const h = Math.floor(t / 3600);
        const m = Math.floor((t % 3600) / 60);
        const s = t % 60;
        const mm = String(m).padStart(h > 0 ? 2 : 1, '0');
        const ss = String(s).padStart(2, '0');
        return h > 0 ? `${h}:${mm}:${ss}` : `${mm}:${ss}`;
      }

      function seekPct(audio) {
        if (!audio.duration) return 0;
        return (audio.currentTime / audio.duration) * 100;
      }

      function bindAudio(player, audio, seek, currentTimeEl, durationEl) {
        audio.addEventListener('loadedmetadata', () => {
          durationEl.textContent = fmt(audio.duration);
          seek.max = 1000;
        });

        audio.addEventListener('timeupdate', () => {
          if (!audio.duration) return;
          const pct = seekPct(audio);
          seek.value = pct * 10;
          seek.style.setProperty('--seek-pct', pct + '%');
          currentTimeEl.textContent = fmt(audio.currentTime);
        });

        audio.addEventListener('ended', () => {
          player.classList.remove('is-playing');
          player.querySelector('[data-play-pause]').setAttribute('aria-label', 'Play');
          activeAudio = null;
          activePlayer = null;
        });
      }

      document.addEventListener('click', e => {
        const btn = e.target.closest('[data-play-pause]');
        if (!btn) return;

        const player = btn.closest('[data-audio-player]');
        const audio  = player.querySelector('[data-audio]');
        const seek   = player.querySelector('[data-seek]');
        const currentTimeEl = player.querySelector('[data-current-time]');
        const durationEl    = player.querySelector('[data-duration]');

        if (!audio._bound) {
          bindAudio(player, audio, seek, currentTimeEl, durationEl);
          audio._bound = true;
        }

        if (audio.paused) {
          if (activeAudio && activeAudio !== audio) {
            activeAudio.pause();
            activePlayer.classList.remove('is-playing');
            activePlayer.querySelector('[data-play-pause]').setAttribute('aria-label', 'Play');
          }
          audio.play();
          player.classList.add('is-playing');
          btn.setAttribute('aria-label', 'Pause');
          activeAudio  = audio;
          activePlayer = player;
        } else {
          audio.pause();
          player.classList.remove('is-playing');
          btn.setAttribute('aria-label', 'Play');
          activeAudio  = null;
          activePlayer = null;
        }
      });

      document.addEventListener('input', e => {
        const seek = e.target.closest('[data-seek]');
        if (!seek) return;

        const player = seek.closest('[data-audio-player]');
        const audio  = player.querySelector('[data-audio]');
        if (!audio.duration) return;

        const pct = seek.value / 10;
        audio.currentTime = (pct / 100) * audio.duration;
        seek.style.setProperty('--seek-pct', pct + '%');
        player.querySelector('[data-current-time]').textContent = fmt(audio.currentTime);
      });
    </script>
  </body>
</html>

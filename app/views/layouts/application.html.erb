<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Ohdio Rss" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Ohdio Rss">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app %>
  </head>

  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <%= link_to 'Ohdio RSS', feeds_path, class: 'site-title' %>
        <%= form_with url: search_path, method: :get, local: true, html: { class: 'header-search-form' } do %>
          <%= hidden_field_tag :filter, 'all' %>
          <%= text_field_tag :q, params[:q], placeholder: 'Search shows', class: 'header-search-input', aria: { label: 'Search shows' } %>
          <button type="submit" class="header-search-button" aria-label="Search">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M10.5 3a7.5 7.5 0 1 0 4.71 13.34l4.22 4.22 1.06-1.06-4.22-4.22A7.5 7.5 0 0 0 10.5 3Zm0 1.5a6 6 0 1 1 0 12 6 6 0 0 1 0-12Z"/>
            </svg>
          </button>
        <% end %>
      </div>
    </header>

    <main class="page-shell">
      <% if notice.present? %>
        <p><%= notice %></p>
      <% end %>

      <% if alert.present? %>
        <p><%= alert %></p>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
